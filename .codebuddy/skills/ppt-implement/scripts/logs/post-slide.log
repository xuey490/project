 {\n        return $query->where('status', '>=', self::STATUS_INSTALLED);\n    }\n\n    /**\n     * 作用域：已启用\n     *\n     * @param mixed $query\n     * @return mixed\n     */\n    public function scopeEnabled($query)\n    {\n        return $query->where('status', self::STATUS_ENABLED);\n    }\n\n    /**\n     * 检查是否已安装\n     *\n     * @return bool\n     */\n    public function isInstalled(): bool\n    {\n        return $this->status >= self::STATUS_INSTALLED;\n    }\n\n    /**\n     * 检查是否已启用\n     *\n     * @return bool\n     */\n    public function isEnabled(): bool\n    {\n        return $this->status === self::STATUS_ENABLED;\n    }\n}\n","file_path":"/workspace/app/Models/SysPlugin.php"},"tool_response":"Successfully created and wrote to new file: /workspace/app/Models/SysPlugin.php","client":"CLI","version":"2.66.2","generation_id":"6eb1698f355f40d8a172cd5a13e17dba","model":"glm-5.0"}
