')]\n    #[Auth(required: true, roles: ['super_admin'])]\n    public function flush(Request $request): BaseJsonResponse\n    {\n        $result = $this->redisService->flushAll();\n        return $result\n            ? $this->success([], '缓存已清空')\n            : $this->fail('清空缓存失败');\n    }\n}\n","file_path":"/workspace/app/Controllers/System/RedisController.php"},"tool_response":"Successfully created and wrote to new file: /workspace/app/Controllers/System/RedisController.php","client":"CLI","version":"2.55.1","generation_id":"e7ecda7f5c2040e581ab762b14aff82b","model":"glm-5.0"}
