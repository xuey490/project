lable();\n            $table->string('status')->default('draft');\n            $table->timestamps();\n            $table->softDeletes();\n        });\n    }\n    \n    public function down(): void\n    {\n        $this->db->schema()->dropIfExists('posts');\n    }\n}\n```\n\n### 9.4 迁移执行器\n\n**`framework/Plugin/Migration/MigrationRunner.php`**：\n\n```php\n<?php\nnamespace Framework\\Plugin\\Migration;\n\nclass MigrationRunner\n{\n    private string $migrationTable = 'plugin_migrations';\n    \n    /**\n     * 执行插件迁移\n     */\n    public function run(string $pluginName): array\n    {\n        $migrations = $this->getPendingMigrations($pluginName);\n        $executed = [];\n        \n        foreach ($migrations as $migration) {\n            $instance = new $migration();\n            $instance->up();\n            \n            $this->recordMigration($pluginName, $migration);\n            $executed[] = $migration;\n        }\n        \n        return $executed;\n    }\n    \n    /**\n     * 回滚插件迁移\n     */\n    public function rollback(string $pluginName): array\n    {\n        // 回滚逻辑\n    }\n    \n    private function getPendingMigrations(string $pluginName): array\n    {\n        // 获取待执行迁移\n    }\n    \n    private function recordMigration(string $pluginName, string $migration): void\n    {\n        // 记录已执行迁移\n    }\n}\n```\n\n---\n\n## 十、CLI 命令设计\n\n### 10.1 命令列表\n\n| 命令 | 说明 |\n|------|------|\n| `php novaphp plugin:list` | 列出所有插件（已安装/未安装） |\n| `php novaphp plugin:install {name}` | 安装插件（执行迁移、注册服务） |\n| `php novaphp plugin:uninstall {name}` | 卸载插件（回滚迁移、清理配置） |\n| `php novaphp plugin:enable {name}` | 启用插件 |\n| `php novaphp plugin:disable {name}` | 禁用插件 |\n| `php novaphp plugin:migrate {name}` | 执行插件迁移 |\n| `php novaphp plugin:rollback {name}` | 回滚插件迁移 |\n| `php novaphp make:plugin {name}` | 创建插件骨架 |\n\n### 10.2 命令实现示例\n\n**`framework/Console/Commands/PluginInstallCommand.php`**：\n\n```php\n<?php\nnamespace Framework\\Console\\Commands;\n\nuse Framework\\Plugin\\PluginManager;\nuse Framework\\Plugin\\Migration\\MigrationRunner;\nuse Symfony\\Component\\Console\\Command\\Command;\nuse Symfony\\Component\\Console\\Input\\InputArgument;\nuse Symfony\\Component\\Console\\Input\\InputInterface;\nuse Symfony\\Component\\Console\\Output\\OutputInterface;\n\nclass PluginInstallCommand extends Command\n{\n    protected static $defaultName = 'plugin:install';\n    \n    protected function configure(): void\n    {\n        $this->setDescription('安装插件')\n             ->addArgument('name', InputArgument::REQUIRED, '插件名称');\n    }\n    \n    protected function execute(InputInterface $input, OutputInterface $output): int\n    {\n        $name = $input->getArgument('name');\n        \n        $manager = new PluginManager(require BASE_PATH . '/config/plugin/plugins.php');\n        $runner = new MigrationRunner();\n        \n        // 1. 发现插件\n        $manager->discover();\n        \n        // 2. 检查依赖\n        if (!$manager->checkDependencies($name)) {\n            $output->error(\"依赖检查失败\");\n            return Command::FAILURE;\n        }\n        \n        // 3. 执行迁移\n        $output->writeln(\"执行数据库迁移...\");\n        $migrations = $runner->run($name);\n        $output->writeln(\"已执行 \" . count($migrations) . \" 个迁移文件\");\n        \n        // 4. 注册插件\n        $manager->install($name);\n        \n        $output->success(\"插件 [{$name}] 安装成功\");\n        return Command::SUCCESS;\n    }\n}\n```\n\n---\n\n## 十一、插件隔离机制\n\n### 11.1 隔离策略\n\n```\n┌─────────────────────────────────────────────────────────────┐\n│                     主容器 (Container)                        │\n│  ┌─────────────┐  ┌─────────────┐  ┌─────────────┐          │\n│  │ 主应用服务   │  │ 主应用模型   │  │ 主应用配置   │          │\n│  └─────────────┘  └─────────────┘  └─────────────┘          │\n│         ▲               ▲               ▲                    │\n│         │               │               │                    │\n│  ┌──────┴───────┐ ┌──────┴───────┐ ┌──────┴───────┐         │\n│  │ Blog 插件    │ │ Payment 插件  │ │ 其他插件      │         │\n│  │ ┌─────────┐ │ │ ┌─────────┐   │ │              │         │\n│  │ │Services │ │ │ │Services │   │ │              │         │\n│  │ │Models   │ │ │ │Models   │   │ │              │         │\n│  │ │Controllers│ │ │Controllers│  │ │              │         │\n│  │ └─────────┘ │ │ └─────────┘   │ │              │         │\n│  └─────────────┘ └───────────────┘ └──────────────┘         │\n│                                                              │\n│  插件间访问规则：                                              │\n│  ✅ 插件 → 主应用（允许）                                      │\n│  ❌ 插件 → 插件（需声明依赖）                                   │\n│  ❌ 主应用 → 插件（通过接口访问）                               │\n└─────────────────────────────────────────────────────────────┘\n```\n\n### 11.2 依赖声明与访问控制\n\n```php\n// plugins/blog/plugin.json\n{\n    \"dependencies\": {\n        \"payment\": \"^1.0.0\"  // 声明依赖 payment 插件\n    }\n}\n\n// 插件中访问其他插件\nnamespace Plugins\\Blog\\Services;\n\nuse Framework\\Plugin\\PluginManager;\n\nclass PostService\n{\n    public function __construct(\n        private PluginManager $pluginManager\n    ) {}\n    \n    public function createPaidPost(array $data): void\n    {\n        // 通过插件管理器获取其他插件服务\n        if ($this->pluginManager->isLoaded('payment')) {\n            $paymentService = $this->pluginManager->getService('payment', 'PaymentService');\n            $paymentService->createOrder($data);\n        }\n    }\n}\n```\n\n---\n\n## 十二、向后兼容性"},"tool_response":"Successfully edited file: /root/.codebuddy/plans/blazing-forging-turing.md","client":"CLI","version":"2.66.2","generation_id":"1143d259111344fd94fe2cb58e714723","model":"glm-5.0"}
