('插件配置文件不存在: ' . $configFile);\n            return Command::FAILURE;\n        }\n\n        $config = require $configFile;\n        $manager = new PluginManager($config);\n        $manager->discover();\n\n        // 检查插件是否已安装\n        if (!$manager->isInstalled($name)) {\n            $io->error(\"插件 '{$name}' 未安装\");\n            return Command::FAILURE;\n        }\n\n        // 检查是否已禁用\n        if (!$manager->isEnabled($name)) {\n            $io->warning(\"插件 '{$name}' 已处于禁用状态\");\n            return Command::SUCCESS;\n        }\n\n        // 执行禁用\n        try {\n            $result = $manager->disable($name);\n\n            if ($result['success']) {\n                $io->success($result['message']);\n            } else {\n                $io->error($result['message']);\n                return Command::FAILURE;\n            }\n        } catch (\\Throwable $e) {\n            $io->error(\"禁用失败: \" . $e->getMessage());\n            return Command::FAILURE;\n        }\n\n        return Command::SUCCESS;\n    }\n}\n","file_path":"/workspace/framework/Console/Commands/PluginDisableCommand.php"},"tool_response":"Successfully created and wrote to new file: /workspace/framework/Console/Commands/PluginDisableCommand.php","client":"CLI","version":"2.66.2","generation_id":"a15deea465394d6580e8cb3278838d93","model":"glm-5.0"}
