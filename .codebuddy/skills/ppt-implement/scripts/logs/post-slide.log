AM', 'tenant_id'),\n\n    /**\n     * 调试模式\n     * 开启后允许从 Query 参数获取租户ID（仅用于开发环境）\n     */\n    'tenant_debug' => env('JWT_TENANT_DEBUG', false),\n];"},"tool_response":"Successfully edited file: /workspace/config/jwt.php","client":"CLI","version":"2.55.1","generation_id":"0af2d09c105741679e27b95a6e1ce32e","model":"kimi-k2.5"}
